# AI Resume Screening System - Environment Variables Template

# ==========================================
# BACKEND ENVIRONMENT VARIABLES
# ==========================================

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=prod

# Database Configuration (Production - Render)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-database-render-com:5432/resume_ai
SPRING_DATASOURCE_USERNAME=resume_ai_user
SPRING_DATASOURCE_PASSWORD=your_secure_password

# Frontend URL for CORS
APP_FRONTEND_URL=https://your-frontend.vercel.app

# JWT Configuration (IMPORTANT: Generate secure secret for production!)
APP_JWT_SECRET=generate_secure_jwt_secret_here_minimum_32_characters
APP_JWT_EXPIRATION_MS=86400000

# File Storage Configuration
APP_STORAGE_UPLOAD_DIR=/tmp/uploads

# Port (Render sets this automatically)
PORT=8080

# ==========================================
# FRONTEND ENVIRONMENT VARIABLES
# ==========================================

# API Base URL (Production)
VITE_API_BASE_URL=https://your-backend.onrender.com/api

# ==========================================
# DEPLOYMENT NOTES
# ==========================================
# 1. For Render deployment:
#    - Set SPRING_PROFILES_ACTIVE=prod
#    - Use Render's database connection strings
#    - Set APP_FRONTEND_URL to your Vercel domain
#    - Generate a secure APP_JWT_SECRET (use: openssl rand -base64 32)
#
# 2. For Vercel deployment:
#    - Set VITE_API_BASE_URL to your Render backend URL
#    - Configure custom domain if needed
#
# 3. Security:
#    - Never commit actual secrets to git
#    - Use environment variable management in deployment platforms
#    - Rotate secrets regularly
